# Shared
NODE_ENV=development

# Frontend (artifacts/inventory-dashboard)
PORT=5173
BASE_PATH=/

# Inventory runs directly against a Google Apps Script Web App.
# The current working deployment is prefilled so the inventory page works out of the box.
# Replace it with your own deployed Apps Script URL when you publish your copy.
VITE_INVENTORY_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbzd4At0brYUEutIj7Ae8cLTmsx5OnFqg4cnfWftNRQWGxdbkSCFwFyiwKdzstx8GxjrNQ/exec

# Optional legacy API base URL.
# Only needed for dashboard / sales / purchases / customers / suppliers,
# which still use the existing Express/Postgres backend in this repo.
VITE_API_BASE_URL=

# API (artifacts/api-server) - legacy backend, still used by non-inventory pages
PORT_API=3000
DATABASE_URL=
